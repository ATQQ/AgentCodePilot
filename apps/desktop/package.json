{
  "name": "@agent-code-pilot/desktop",
  "version": "0.0.1",
  "description": "AgentCodePilot desktop application",
  "homepage": "https://github.com/ATQQ/AgentCodePilot",
  "main": "./out/main/index.js",
  "author": "sugar",
  "scripts": {
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "analyze": "ANALYZE=1 electron-vite build",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w better-sqlite3,node-pty",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:win": "pnpm build && electron-builder --win --x64",
    "build:win:release": "pnpm build && electron-builder --config electron-builder.release.yml --win --x64",
    "build:mac": "pnpm build && electron-builder --mac --arm64",
    "build:mac:x64": "pnpm build && electron-builder --mac --x64",
    "build:mac:release": "pnpm build && electron-builder --config electron-builder.release.yml --mac --arm64 --x64",
    "build:linux": "pnpm build && electron-builder --linux --x64",
    "build:linux:arm64": "pnpm build && electron-builder --linux --arm64",
    "build:linux:release": "pnpm build && electron-builder --config electron-builder.release.yml --linux --x64 --arm64"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@cursor/sdk": "^1.0.22",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@element-plus/icons-vue": "^2.3.2",
    "@openai/codex-sdk": "^0.142.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.3.9",
    "element-plus": "^2.14.1",
    "katex": "^0.17.0",
    "markstream-vue": "1.0.1-beta.5",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "pinia": "^3.0.4",
    "simple-git": "^3.36.0",
    "stream-monaco": "^0.0.42",
    "vue-i18n": "^11.4.5",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^41.7.2",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^7.2.6",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  }
}
